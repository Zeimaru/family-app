rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }
    function isAuthor() {
      return resource.data.authorId == request.auth.uid;
    }
    function canRead() {
      return resource.data.shared == true || resource.data.authorId == request.auth.uid;
    }
    function isMyDoc() {
      return request.resource.data.authorId == request.auth.uid;
    }

    // 유저 프로필 (familyId 저장용)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /families/{familyId} {
      allow read:   if request.auth != null && isMember(familyId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && isMember(familyId);

      match /members/{memberId} {
        allow read:           if request.auth != null && isMember(familyId);
        allow create, update: if request.auth != null && memberId == request.auth.uid;
      }
      match /books/{bookId} {
        allow read:           if request.auth != null && isMember(familyId) && canRead();
        allow create:         if request.auth != null && isMember(familyId) && isMyDoc();
        allow update, delete: if request.auth != null && isMember(familyId) && isAuthor();
      }
      match /worksheets/{wsId} {
        allow read:           if request.auth != null && isMember(familyId) && canRead();
        allow create:         if request.auth != null && isMember(familyId) && isMyDoc();
        allow update, delete: if request.auth != null && isMember(familyId) && isAuthor();
      }
      match /todos/{todoId} {
        allow read:           if request.auth != null && isMember(familyId) && canRead();
        allow create:         if request.auth != null && isMember(familyId) && isMyDoc();
        allow update, delete: if request.auth != null && isMember(familyId) && isAuthor();
      }
      match /events/{eventId} {
        allow read:           if request.auth != null && isMember(familyId) && canRead();
        allow create:         if request.auth != null && isMember(familyId) && isMyDoc();
        allow update, delete: if request.auth != null && isMember(familyId) && isAuthor();
      }
      match /growth/{growthId} {
        allow read:           if request.auth != null && isMember(familyId) && canRead();
        allow create:         if request.auth != null && isMember(familyId) && isMyDoc();
        allow update, delete: if request.auth != null && isMember(familyId) && isAuthor();
      }
    }
  }
}
